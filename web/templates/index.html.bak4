<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>PathSteer Guardian</title>
<style>
:root {
    --bg:#0a0a0f;--panel:#12121a;--card:#1a1a2e;--border:#2a2a4e;
    --text:#e0e0e0;--muted:#666;--dim:#444;
    --blue:#00d4ff;--purple:#7b2cbf;--green:#00ff88;
    --yellow:#ffaa00;--orange:#ff6600;--red:#ff4444;
    --sl-blue:#1DA1F2;--tmo-magenta:#E20074;--att-blue:#00A8E0;
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'SF Mono','Fira Code','Consolas',monospace;background:var(--bg);color:var(--text);font-size:11px;overflow:hidden;-webkit-user-select:none;user-select:none}

/* ═══ 2-COL + BOTTOM BAR LAYOUT ═══ */
.dashboard{
    display:grid;
    grid-template-columns:240px 1fr;
    grid-template-rows:42px 1fr 140px;
    height:100vh;gap:1px;background:var(--border);
}

/* ═══ HEADER ═══ */
.header{
    grid-column:1/-1;background:linear-gradient(90deg,var(--panel),#1a1a30);
    display:flex;justify-content:space-between;align-items:center;padding:0 12px;
}
.logo{display:flex;align-items:center;gap:6px}
.logo h1{font-size:13px;font-weight:700;letter-spacing:2px}
.logo .g{color:var(--blue)}
.hdr-center{display:flex;align-items:center;gap:8px}
.badge{padding:3px 8px;border-radius:3px;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1px}
.mode-training{background:rgba(0,212,255,.15);color:var(--blue);border:1px solid var(--blue)}
.mode-tripwire{background:rgba(255,170,0,.15);color:var(--yellow);border:1px solid var(--yellow)}
.mode-mirror{background:rgba(0,255,136,.15);color:var(--green);border:1px solid var(--green)}
.mode-ecmp{background:rgba(0,212,255,.15);color:var(--blue);border:1px solid var(--blue);animation:pulse 1.5s infinite}
.st-normal{background:rgba(0,255,136,.08);color:var(--green)}
.st-prepare,.st-prepare{background:rgba(255,170,0,.1);color:var(--yellow);animation:pulse 1.5s infinite}
.st-protect{background:rgba(255,102,0,.12);color:var(--orange);animation:pulse .8s infinite}
.st-switching{background:rgba(255,68,68,.12);color:var(--red);animation:pulse .5s infinite}
.st-holding{background:rgba(123,44,191,.12);color:var(--purple)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.6}}
.speed-hdr{font-size:18px;font-weight:700;color:var(--blue);display:flex;gap:8px;align-items:baseline}
.speed-hdr .down-spd{color:var(--green)}.speed-hdr .up-spd{color:var(--purple)}
.speed-hdr .u{font-size:9px;color:var(--muted)}
.hdr-right{display:flex;gap:4px;align-items:center}
.hdr-btn{padding:3px 8px;background:var(--card);border:1px solid var(--border);color:var(--text);
    font-size:9px;font-family:inherit;cursor:pointer;border-radius:3px;text-decoration:none;white-space:nowrap}
.hdr-btn:hover{border-color:var(--blue);color:var(--blue)}

/* ═══ LEFT PANE ═══ */
.left-pane{background:var(--panel);overflow-y:auto;display:flex;flex-direction:column}
.section-title{font-size:8px;text-transform:uppercase;letter-spacing:2px;color:var(--muted);
    padding:6px 8px 3px;flex-shrink:0}
.uplinks-list{overflow-y:auto;padding:4px 6px;flex:1;min-height:0}

/* Uplink Cards */
.uc{background:var(--card);border-radius:4px;padding:6px 7px;margin-bottom:4px;
    border:2px solid var(--border);position:relative;transition:all .15s}
.uc.active{border-color:var(--green);box-shadow:0 0 8px rgba(0,255,136,.12)}
.uc.active .uc-active-dot{display:inline}
.uc.unavail{opacity:.3}.uc.disabled-ul{opacity:.35;border-style:dashed}
.uc.disabled-ul .uc-dis-label{display:block}
.uc.lte{border-left:3px solid var(--tmo-magenta)}.uc.att{border-left-color:var(--att-blue)}
.uc.starlink{border-left:3px solid var(--sl-blue)}.uc.fiber{border-left:3px solid var(--green)}
.uc-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:3px}
.uc-name{font-weight:700;font-size:10px}
.uc-type{font-size:8px;color:var(--muted);margin-left:4px}
.uc-active-dot{display:none;color:var(--green);font-size:7px;animation:blink 1s infinite;margin-left:4px}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.uc-dis-label{display:none;position:absolute;top:3px;right:7px;font-size:7px;color:var(--red);font-weight:700;text-transform:uppercase}
.uc-right{display:flex;align-items:center;gap:4px}
.pred-badge{font-size:7px;font-weight:700;padding:1px 4px;border-radius:2px}
.pred-badge.next{background:var(--yellow);color:#000}.pred-badge.p2{background:#555;color:#ccc}.pred-badge.p3{background:#333;color:#999}
.tog{width:26px;height:13px;border-radius:7px;background:var(--border);cursor:pointer;
    position:relative;transition:background .15s;flex-shrink:0}
.tog.on{background:var(--green)}
.tog::after{content:'';position:absolute;top:2px;left:2px;width:9px;height:9px;border-radius:50%;background:var(--text);transition:left .15s}
.tog.on::after{left:15px}
.mg{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-bottom:2px}
.mc{background:var(--bg);padding:2px;border-radius:2px;text-align:center}
.mc .l{font-size:7px;color:var(--muted);text-transform:uppercase}.mc .v{font-size:9px;font-weight:600;color:var(--blue)}
.mc .v.g{color:var(--green)}.mc .v.w{color:var(--yellow)}.mc .v.b{color:var(--red)}.mc .v.na{color:var(--dim)}
.xm{font-size:8px;color:var(--muted);padding:1px 0}
.risk-bar{height:4px;background:var(--bg);border-radius:2px;overflow:hidden;margin-top:2px}
.risk-fill{height:100%;border-radius:2px;transition:width .3s}

/* Actions */
.actions-section{padding:4px 6px;border-top:1px solid var(--border);flex-shrink:0}
.act-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:3px}
.act-btn{padding:4px 2px;background:var(--card);border:1px solid var(--border);color:var(--text);
    font-size:8px;font-family:inherit;cursor:pointer;border-radius:2px;text-align:center}
.act-btn:hover{border-color:var(--blue);color:var(--blue)}
.act-btn.danger{border-color:rgba(255,68,68,.3);color:var(--red)}

/* WG Compact */
.wg-compact{padding:4px 6px;border-top:1px solid var(--border);flex-shrink:0}
.wg-row{display:flex;justify-content:space-between;align-items:center;padding:1px 0;font-size:8px}
.wg-dot{width:5px;height:5px;border-radius:50%;display:inline-block;margin-right:3px}
.wg-dot.up{background:var(--green)}.wg-dot.stale{background:var(--yellow)}.wg-dot.down{background:var(--red)}
.wg-rate{color:var(--blue);font-size:8px;font-weight:600}

/* ═══ MAIN AREA ═══ */
.main-area{background:var(--panel);display:flex;flex-direction:column;overflow:hidden}
.view-tabs{display:none}
.vtab{padding:7px 14px;background:none;border:none;color:var(--muted);font-size:9px;font-weight:600;
    font-family:inherit;cursor:pointer;text-transform:uppercase;letter-spacing:1px;
    border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .15s}
.vtab:hover{color:var(--text)}.vtab.active{color:var(--blue);border-bottom-color:var(--blue)}
.view-content{flex:1;overflow-y:auto;padding:8px;position:relative}
.vp{max-height:0;overflow:hidden;transition:max-height .4s ease,opacity .3s ease;opacity:0}.vp.active{max-height:3000px;opacity:1;overflow-y:auto}
.acc-hdr{padding:8px 12px;background:var(--card);border:1px solid var(--border);color:var(--blue);font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;margin-top:2px;display:flex;justify-content:space-between;align-items:center;transition:background .2s}
.acc-hdr:hover{background:var(--border)}
.acc-hdr .arrow{transition:transform .3s;font-size:8px}
.acc-hdr.open .arrow{transform:rotate(180deg)}

/* Active path banner */
.apb{background:linear-gradient(135deg,rgba(0,255,136,.03),rgba(0,212,255,.03));
    border:1px solid var(--green);border-radius:4px;padding:8px 12px;margin-bottom:8px;
    display:flex;justify-content:space-between;align-items:center}
.apb.warn{border-color:var(--yellow)}
.apb .pn{font-size:14px;font-weight:700;color:var(--green)}
.apb .pd{font-size:8px;color:var(--muted);margin-left:8px}
.badge-sm{display:inline-block;padding:2px 5px;border-radius:2px;font-size:8px;font-weight:600}

/* KPI row */
.kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin-bottom:8px}
.kpi{background:var(--card);border:1px solid var(--border);border-radius:4px;padding:6px;text-align:center}
.kpi .val{font-size:18px;font-weight:700;color:var(--blue)}.kpi .lbl{font-size:7px;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-top:1px}
.kpi .sub{font-size:8px;color:var(--muted)}

/* Throughput bars */
.tp-section{margin-bottom:8px}
.tp-row{display:flex;align-items:center;gap:6px;margin-bottom:4px}
.tp-label{font-size:8px;color:var(--muted);min-width:24px;text-align:right}
.tp-bar{flex:1;height:12px;background:var(--bg);border-radius:6px;overflow:hidden;position:relative}
.tp-fill{height:100%;border-radius:6px;transition:width .3s ease;min-width:2px}
.tp-fill.down{background:linear-gradient(90deg,#005577,var(--green))}
.tp-fill.up{background:linear-gradient(90deg,#440077,var(--purple))}
.tp-val{font-size:10px;font-weight:700;min-width:70px}
.tp-val.dv{color:var(--green)}.tp-val.uv{color:var(--purple)}
.tp-peak{font-size:8px;color:var(--dim);min-width:50px}

/* Throughput chart canvas */
.tp-chart{height:100px;background:var(--bg);border:1px solid var(--border);border-radius:4px;margin-bottom:8px;position:relative}
.tp-chart canvas{width:100%;height:100%;border-radius:4px}

/* Prediction */
.pred-section{background:var(--card);border:1px solid var(--border);border-radius:4px;padding:8px;margin-bottom:8px}
.pred-section h3{font-size:8px;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-bottom:4px}
.pred-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:4px}
.pred-item{text-align:center}.pred-item .rank{font-size:7px;color:var(--muted);text-transform:uppercase}
.pred-item .name{font-size:10px;font-weight:700;color:var(--blue)}.pred-item .name.act{color:var(--green)}

/* ─── DIAG VIEW ─── */
.diag-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:8px}
.diag-card{background:var(--card);border:1px solid var(--border);border-radius:4px;padding:8px}
.diag-card h3{font-size:8px;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-bottom:6px}
.stat-row{display:flex;justify-content:space-between;padding:3px 0;border-bottom:1px solid rgba(42,42,78,.2)}
.stat-row:last-child{border-bottom:none}
.stat-lbl{color:var(--muted)}.stat-val{font-weight:600;color:var(--blue)}
.stat-val.g{color:var(--green)}.stat-val.w{color:var(--yellow)}.stat-val.b{color:var(--red)}
.ns-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:4px;margin-top:6px}
.ns-card{background:var(--bg);border:1px solid var(--border);border-radius:3px;padding:4px;font-size:8px}
.ns-card.ok{border-left:2px solid var(--green)}.ns-card.bad{border-left:2px solid var(--red)}
.ns-card .nn{font-weight:700;margin-bottom:2px}.ns-card .nd{color:var(--muted);line-height:1.4}

/* ─── WG TUNNELS VIEW ─── */
.tun-table{width:100%;border-collapse:collapse;font-size:9px}
.tun-table th{text-align:left;padding:5px 6px;background:var(--bg);color:var(--muted);font-size:7px;text-transform:uppercase;letter-spacing:1px;border-bottom:2px solid var(--border)}
.tun-table td{padding:5px 6px;border-bottom:1px solid var(--border)}
.tun-table tr:hover{background:rgba(0,212,255,.02)}
.sd{display:inline-block;width:6px;height:6px;border-radius:50%;margin-right:3px}
.sd.up{background:var(--green);box-shadow:0 0 3px var(--green)}.sd.stale{background:var(--yellow)}.sd.down{background:var(--red)}
.ctrl-b{display:inline-block;padding:1px 5px;border-radius:2px;font-size:7px;font-weight:600}
.ctrl-b.a{background:rgba(0,212,255,.1);color:var(--blue)}.ctrl-b.b{background:rgba(123,44,191,.1);color:var(--purple)}

/* ═══ BOTTOM — EVENT LOG ═══ */
.bottom-bar{grid-column:1/-1;background:var(--panel);display:flex;flex-direction:column;overflow:hidden;border-top:2px solid var(--border)}
.log-header{display:flex;justify-content:space-between;align-items:center;padding:4px 10px;flex-shrink:0}
.log-header .lt{font-size:8px;text-transform:uppercase;letter-spacing:2px;color:var(--muted)}
.log-controls{display:flex;gap:3px}
.log-btn{padding:2px 6px;background:var(--card);border:1px solid var(--border);color:var(--muted);
    font-size:7px;font-family:inherit;cursor:pointer;border-radius:2px}
.log-btn:hover{color:var(--text)}.log-btn.active{color:var(--blue);border-color:var(--blue)}
.log-content{flex:1;overflow-y:auto;padding:0 10px;display:flex;flex-direction:column-reverse}
.log-inner{display:flex;flex-direction:column}
.le{padding:1px 0;font-size:8px;line-height:1.3;border-bottom:1px solid rgba(42,42,78,.15)}
.le .lt2{color:var(--dim);margin-right:4px;font-size:7px}
.le .ll{font-weight:700;margin-right:3px;font-size:7px}
.le .ll.info{color:var(--blue)}.le .ll.warn{color:var(--yellow)}.le .ll.switch{color:var(--green)}
.le .ll.trigger{color:var(--red)}.le .ll.error{color:var(--red)}.le .ll.predict{color:var(--purple)}

/* ═══ MOBILE ═══ */
@media(max-width:768px){
    .dashboard{grid-template-columns:1fr;grid-template-rows:48px 1fr 120px}
    .left-pane{display:none}
    .header{padding:0 8px}
    .hdr-right .hdr-btn{display:none}
    .hdr-right .hdr-btn.mob-show{display:inline-block}
    body{font-size:12px}
    .kpi-row{grid-template-columns:repeat(3,1fr)}
    .kpi .val{font-size:22px}
    .tp-bar{height:18px}
    .uc{padding:10px;margin-bottom:6px}
    .uc-name{font-size:13px}
    .act-btn{padding:10px;font-size:11px}
    .view-tabs{overflow-x:auto}
    .vtab{padding:10px 16px;font-size:11px}
    .speed-hdr{font-size:22px}
}
@media(max-width:480px){
    .kpi-row{grid-template-columns:repeat(2,1fr)}
    .diag-grid{grid-template-columns:1fr}
}
</style>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
</head>
<body>

<div class="dashboard">
<!-- ═══ HEADER ═══ -->
<div class="header">
    <div class="logo"><h1>PATHSTEER <span class="g">GUARDIAN</span></h1></div>
    <div class="hdr-center">
        <span class="badge mode-tripwire" id="badge-mode">TRIPWIRE</span>
        <span class="badge st-normal" id="badge-state">NORMAL</span>
        <span class="badge" id="badge-dup" style="background:rgba(100,100,100,.15);color:var(--muted)">DUP OFF</span>
        <div class="speed-hdr">
            <span class="down-spd" id="spd-down">0.0</span><span class="u">↓</span>
            <span class="up-spd" id="spd-up">0.0</span><span class="u">↑ Mbps</span>
        </div>
    </div>
    <div class="hdr-right">
        <button class="hdr-btn" onclick="chaosFloat()">🎲 Chaos</button>
        <button class="hdr-btn" onclick="llmFloat()">⚡ LLM</button>
        <button class="hdr-btn" onclick="flowFloat()">📡 Flows</button>
        <button class="hdr-btn" onclick="logHistFloat()">📋 History</button>
        <a class="hdr-btn" href="/diag/" target="_blank">🔍 Diag</a>
    </div>
</div>

<!-- ═══ LEFT PANE ═══ -->
<div class="left-pane">
    <div class="section-title">UPLINKS</div>
    <div class="uplinks-list" id="uplinks-list"></div>

    <div class="actions-section">
        <div class="section-title" style="padding:0 0 3px">ACTIONS</div>
        <div class="act-grid">
            <button class="act-btn" onclick="forceActive('fa')">FA</button>
            <button class="act-btn" onclick="forceActive('fb')">FB</button>
            <button class="act-btn" onclick="forceActive('sl_a')">SL_A</button>
            <button class="act-btn" onclick="forceActive('sl_b')">SL_B</button>
            <button class="act-btn" onclick="forceActive('cell_a')">CELL_A</button>
            <button class="act-btn" onclick="forceActive('cell_b')">CELL_B</button>
            <button class="act-btn" onclick="switchController(0)">CTRL-A</button>
            <button class="act-btn" onclick="switchController(1)">CTRL-B</button>
            <button class="act-btn" onclick="clearForce()">AUTO</button>
            <div style="margin-top:6px;padding:6px;background:var(--card);border:1px solid var(--border);border-radius:4px">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
                    <span style="font-size:8px;text-transform:uppercase;letter-spacing:2px;color:var(--muted)">ECMP STRIPING</span>
                    <div id="ecmp-toggle" class="tog" onclick="toggleEcmp()" title="Master ECMP toggle"></div>
                </div>
                <div id="ecmp-links" style="display:flex;flex-wrap:wrap;gap:3px">
                    <label class="ecmp-cb" style="display:flex;align-items:center;gap:3px;font-size:9px;cursor:pointer;padding:2px 5px;background:var(--panel);border-radius:3px;border:1px solid var(--border)">
                        <input type="checkbox" class="ecmp-link" value="fa" checked style="accent-color:var(--green)"> FA</label>
                    <label class="ecmp-cb" style="display:flex;align-items:center;gap:3px;font-size:9px;cursor:pointer;padding:2px 5px;background:var(--panel);border-radius:3px;border:1px solid var(--border)">
                        <input type="checkbox" class="ecmp-link" value="fb" checked style="accent-color:var(--green)"> FB</label>
                    <label class="ecmp-cb" style="display:flex;align-items:center;gap:3px;font-size:9px;cursor:pointer;padding:2px 5px;background:var(--panel);border-radius:3px;border:1px solid var(--border)">
                        <input type="checkbox" class="ecmp-link" value="sl_a" style="accent-color:var(--sl-blue)"> SL_A</label>
                    <label class="ecmp-cb" style="display:flex;align-items:center;gap:3px;font-size:9px;cursor:pointer;padding:2px 5px;background:var(--panel);border-radius:3px;border:1px solid var(--border)">
                        <input type="checkbox" class="ecmp-link" value="sl_b" style="accent-color:var(--sl-blue)"> SL_B</label>
                    <label class="ecmp-cb" style="display:flex;align-items:center;gap:3px;font-size:9px;cursor:pointer;padding:2px 5px;background:var(--panel);border-radius:3px;border:1px solid var(--border)">
                        <input type="checkbox" class="ecmp-link" value="cell_a" style="accent-color:var(--tmo-magenta)"> CELL_A</label>
                    <label class="ecmp-cb" style="display:flex;align-items:center;gap:3px;font-size:9px;cursor:pointer;padding:2px 5px;background:var(--panel);border-radius:3px;border:1px solid var(--border)">
                        <input type="checkbox" class="ecmp-link" value="cell_b" style="accent-color:var(--att-blue)"> CELL_B</label>
                </div>
                <div id="ecmp-status" style="font-size:8px;color:var(--muted);margin-top:3px">OFF</div>
            </div>
        </div>
    </div>

    <div class="wg-compact">
        <div class="section-title" style="padding:0 0 3px;display:flex;justify-content:space-between">
            <span>WG TUNNELS</span><span id="wg-sum" style="color:var(--blue);font-weight:600">--/12</span>
        </div>
        <div id="wg-rows"><span style="color:var(--dim)">Loading...</span></div>
    </div>
</div>

<!-- ═══ MAIN AREA ═══ -->
<div class="main-area">
    <div class="view-tabs">
        <button class="vtab active" onclick="switchView('status',this)">Status</button>
        <button class="vtab" onclick="switchView('diag',this)">Diagnostics</button>
        <button class="vtab" onclick="switchView('tunnels',this)">WG Tunnels</button>
    </div>
    <div class="view-content">
        <!-- STATUS VIEW -->
        <div class="acc-hdr open" onclick="toggleAcc(this,'status')">STATUS <span class="arrow">▼</span></div>
        <div class="vp active" id="view-status">
            <div class="apb" id="apb">
                <div style="display:flex;align-items:center">
                    <span class="sd up"></span>
                    <span class="pn" id="ap-name">--</span>
                    <span class="pd" id="ap-detail">Loading...</span>
                </div>
                <div>
                    <span class="badge-sm" id="ctrl-badge" style="background:rgba(0,212,255,.1);color:var(--blue)">CTRL-A</span>
                    <span class="badge-sm" id="cmd-badge" style="background:rgba(100,100,100,.1);color:var(--muted)">--</span>
                </div>
            </div>

            <div class="kpi-row">
                <div class="kpi"><div class="val" id="kpi-paths">--</div><div class="lbl">Paths Up</div></div>
                <div class="kpi"><div class="val" id="kpi-best">--</div><div class="lbl">Best RTT</div><div class="sub" id="kpi-best-n">--</div></div>
                <div class="kpi"><div class="val" id="kpi-risk">--</div><div class="lbl">Risk</div></div>
                <div class="kpi"><div class="val" id="kpi-up">--</div><div class="lbl">Uptime</div></div>
                <div class="kpi"><div class="val" id="kpi-sw">0</div><div class="lbl">Switches</div></div>
            </div>

            <div class="tp-section">
                <div class="tp-row">
                    <span class="tp-label">↓</span>
                    <div class="tp-bar"><div class="tp-fill down" id="tp-d-fill" style="width:0%"></div></div>
                    <span class="tp-val dv" id="tp-d-val">0.0 Mbps</span>
                    <span class="tp-peak" id="tp-d-peak">peak: 0</span>
                </div>
                <div class="tp-row">
                    <span class="tp-label">↑</span>
                    <div class="tp-bar"><div class="tp-fill up" id="tp-u-fill" style="width:0%"></div></div>
                    <span class="tp-val uv" id="tp-u-val">0.0 Mbps</span>
                    <span class="tp-peak" id="tp-u-peak">peak: 0</span>
                </div>
            </div>

            <div class="tp-chart"><canvas id="tp-canvas"></canvas></div>

            <div class="pred-section">
                <h3>Path Prediction</h3>
                <div class="pred-grid">
                    <div class="pred-item"><div class="rank">Active</div><div class="name act" id="pred-a">--</div></div>
                    <div class="pred-item"><div class="rank">Next</div><div class="name" id="pred-1">--</div></div>
                    <div class="pred-item"><div class="rank">2nd</div><div class="name" id="pred-2">--</div></div>
                    <div class="pred-item"><div class="rank">3rd</div><div class="name" id="pred-3">--</div></div>
                </div>
            </div>
        </div>

        <!-- MOBILE VIEW -->
        <div class="acc-hdr" onclick="toggleAcc(this,'mobile')">MOBILE / GPS <span class="arrow">▼</span></div>
        <div class="vp" id="view-mobile">
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:8px">
                <div class="kpi"><div class="val" id="gps-speed">0</div><div class="lbl">MPH</div></div>
                <div class="kpi"><div class="val" id="gps-heading">--</div><div class="lbl">Heading</div></div>
                <div class="kpi"><div class="val" id="gps-lat">--</div><div class="lbl">Latitude</div></div>
                <div class="kpi"><div class="val" id="gps-lon">--</div><div class="lbl">Longitude</div></div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px">
                <div class="diag-card"><h3>GPS Status</h3>
                    <div class="stat-row"><span class="stat-lbl">Fix</span><span class="stat-val" id="gps-fix">--</span></div>
                    <div class="stat-row"><span class="stat-lbl">Satellites</span><span class="stat-val" id="gps-sat">--</span></div>
                    <div class="stat-row"><span class="stat-lbl">Accuracy</span><span class="stat-val" id="gps-acc">--</span></div>
                </div>
                <div class="diag-card"><h3>Signal Environment</h3>
                    <div class="stat-row"><span class="stat-lbl">Cell Tower</span><span class="stat-val" id="gps-cell">--</span></div>
                    <div class="stat-row"><span class="stat-lbl">Handoffs</span><span class="stat-val" id="gps-ho">0</span></div>
                    <div class="stat-row"><span class="stat-lbl">Band</span><span class="stat-val" id="gps-band">--</span></div>
                </div>
            </div>
            <div style="margin-top:6px;border:1px solid var(--border);border-radius:4px;overflow:hidden;height:200px;position:relative">
                <div id="gps-map" style="width:100%;height:100%;background:var(--bg)"></div>
            </div>
        </div>

        <!-- DIAGNOSTICS VIEW -->
        <div class="acc-hdr" onclick="toggleAcc(this,'diag')">DIAGNOSTICS <span class="arrow">▼</span></div>
        <div class="vp" id="view-diag">
            <div class="diag-grid">
                <div class="diag-card"><h3>Failover Performance</h3>
                    <div class="stat-row"><span class="stat-lbl">Tests</span><span class="stat-val" id="fo-t">0</span></div>
                    <div class="stat-row"><span class="stat-lbl">Success</span><span class="stat-val g" id="fo-s">--%</span></div>
                    <div class="stat-row"><span class="stat-lbl">P50 Detect</span><span class="stat-val" id="fo-d50">-- ms</span></div>
                    <div class="stat-row"><span class="stat-lbl">Worst Total</span><span class="stat-val w" id="fo-w">-- ms</span></div>
                </div>
                <div class="diag-card"><h3>Stability</h3>
                    <div class="stat-row"><span class="stat-lbl">Availability</span><span class="stat-val g" id="st-av">--%</span></div>
                    <div class="stat-row"><span class="stat-lbl">Uptime</span><span class="stat-val" id="st-up">--</span></div>
                    <div class="stat-row"><span class="stat-lbl">MTBF</span><span class="stat-val" id="st-mt">--</span></div>
                    <div class="stat-row"><span class="stat-lbl">Failures</span><span class="stat-val" id="st-f">0</span></div>
                </div>
                <div class="diag-card"><h3>System</h3>
                    <div class="stat-row"><span class="stat-lbl">CPU</span><span class="stat-val" id="sy-cpu">--%</span></div>
                    <div class="stat-row"><span class="stat-lbl">Load</span><span class="stat-val" id="sy-ld">--</span></div>
                    <div class="stat-row"><span class="stat-lbl">Memory</span><span class="stat-val" id="sy-mem">--</span></div>
                </div>
                <div class="diag-card"><h3>Active Path Verify</h3>
                    <div class="stat-row"><span class="stat-lbl">OS Route</span><span class="stat-val" id="pv-r">--</span></div>
                    <div class="stat-row"><span class="stat-lbl">Daemon</span><span class="stat-val" id="pv-d">--</span></div>
                    <div class="stat-row"><span class="stat-lbl">Match</span><span class="stat-val" id="pv-m">--</span></div>
                </div>
            </div>
            <div class="section-title">NAMESPACES</div>
            <div class="ns-grid" id="ns-grid"></div>
        </div>

        <!-- WG TUNNELS VIEW -->
        <div class="acc-hdr" onclick="toggleAcc(this,'tunnels')">WG TUNNELS <span class="arrow">▼</span></div>
        <div class="vp" id="view-tunnels">
            <div style="margin-bottom:8px;text-align:right">
                <button class="hdr-btn" onclick="runProbe()" id="probe-btn">⚡ PROBE ALL RTT</button>
            </div>
            <table class="tun-table">
                <thead><tr><th>St</th><th>Tunnel</th><th>Uplink</th><th>Ctrl</th><th>Handshake</th><th>RX</th><th>TX</th><th>RX Rate</th><th>TX Rate</th><th>RTT</th></tr></thead>
                <tbody id="tun-tbody"><tr><td colspan="10" style="text-align:center;color:var(--muted);padding:12px">Loading...</td></tr></tbody>
            </table>
        </div>
    </div>
</div>

<!-- ═══ BOTTOM — EVENT LOG ═══ -->
<div class="bottom-bar">
    <div class="log-header">
        <span class="lt">EVENT LOG</span>
        <div class="log-controls">
            <button class="log-btn active" onclick="filterLog('all',this)">All</button>
            <button class="log-btn" onclick="filterLog('switch',this)">Switch</button>
            <button class="log-btn" onclick="filterLog('trigger',this)">Trigger</button>
            <button class="log-btn" onclick="filterLog('warn',this)">Warn</button>
            <button class="log-btn" onclick="exportLog()">⬇ CSV</button>
        </div>
    </div>
    <div class="log-content" id="log-content"><div class="log-inner" id="log-inner"></div></div>
</div>
</div>

<!-- Hidden LLM state -->
<input type="hidden" id="llm-prompt" value="Explain quantum computing in simple terms">

<script>
/* ═══════════════════════════════════════════════════════════════
   PathSteer Guardian v2 — Unified Dashboard
   ═══════════════════════════════════════════════════════════════ */
const UL={cell_a:'T-Mobile',cell_b:'AT&T',sl_a:'Starlink A',sl_b:'Starlink B',fa:'Fiber A',fb:'Fiber B'};
const UT={cell_a:'lte',cell_b:'lte att',sl_a:'starlink',sl_b:'starlink',fa:'fiber',fb:'fiber'};
const UTL={cell_a:'LTE',cell_b:'LTE',sl_a:'LEO',sl_b:'LEO',fa:'FIBER',fb:'FIBER'};

// View switching
function toggleAcc(hdr,id){
    const vp=document.getElementById("view-"+id);
    const isOpen=vp.classList.contains("active");
    if(isOpen){
        vp.classList.remove("active");
        hdr.classList.remove("open");
    }else{
        vp.classList.add("active");
        hdr.classList.add("open");
        if(id==="diag")fetchDiag();if(id==="tunnels")fetchTunnels(false);
    }
}
function switchView(id,el){toggleAcc(document.querySelector(".acc-hdr.open"),id);}

// ─── Uplink rendering ───
let _lock=0;
function renderUplinks(uplinks,activeUL){
    if(Date.now()<_lock)return;
    const avail=uplinks.filter(u=>u.enabled&&u.available&&!u.active);
    const scored=avail.map(u=>({n:u.name,s:(u.rtt_ms||999)+(u.risk_now||0)*100+(u.loss_pct||0)*10})).sort((a,b)=>a.s-b.s);
    const ti=scored.reduce((s,x)=>s+1000/(x.s+1),0);
    const preds=scored.map(x=>({n:x.n,p:Math.round((1000/(x.s+1))/ti*100)}));
    const pm={};preds.forEach((p,i)=>{pm[p.n]={r:i,p:p.p}});

    document.getElementById('uplinks-list').innerHTML=uplinks.map(u=>{
        const _en=["cell_a","cell_b","sl_a","sl_b","fa","fb"];const isAct=(window._ecmpMode&&window._ecmpMask>0)?(window._ecmpMask&(1<<_en.indexOf(u.name)))>0:u.name===activeUL;
        // Key fix #4: disabled overrides active visually
        const isDisabled=!u.enabled;
        const cls=['uc',
            UT[u.name]?UT[u.name].split(' ')[0]:'',
            UT[u.name]?.includes('att')?'att':'',
            isAct&&!isDisabled?'active':'',
            !u.available&&!isDisabled?'unavail':'',
            isDisabled?'disabled-ul':''
        ].filter(Boolean).join(' ');

        const rtt=u.rtt_ms!=null?u.rtt_ms.toFixed(0)+'ms':'--';
        const loss=u.loss_pct!=null?u.loss_pct.toFixed(1)+'%':'--';
        const rttC=u.rtt_ms==null?'na':u.rtt_ms>150?'b':u.rtt_ms>80?'w':'g';
        const lossC=u.loss_pct==null?'na':u.loss_pct>5?'b':u.loss_pct>1?'w':'g';
        const risk=u.risk_now||0;
        const riskCol=risk>.5?'var(--red)':risk>.2?'var(--yellow)':'var(--green)';

        let extra='';
        if(u.cellular){
            const rp=u.cellular.rsrp!=null?u.cellular.rsrp.toFixed(0):'--';
            const sn=u.cellular.sinr!=null?u.cellular.sinr.toFixed(0):'--';
            extra=`<div class="xm">${rp} dBm / SINR ${sn} / ${u.cellular.carrier||''}</div>`;
        }else if(u.starlink){
            extra=`<div class="xm">${u.starlink.latency?.toFixed(0)||'--'}ms / Obstr ${u.starlink.obstruction_pct?.toFixed(0)||'--'}% / ${u.starlink.state||''}</div>`;
        }

        let predHtml='';
        const p=pm[u.name];
        if(p&&!isAct){
            const pc=p.r===0?'next':p.r===1?'p2':'p3';
            const pl=p.r===0?'NEXT':p.r===1?'2ND':'3RD';
            predHtml=`<span class="pred-badge ${pc}">${pl} ${p.p}%</span>`;
        }

        return `<div class="${cls}" data-name="${u.name}">
            <div class="uc-dis-label">DISABLED</div>
            <div class="uc-hdr">
                <div><span class="uc-name">${UL[u.name]||u.name}</span><span class="uc-type">${UTL[u.name]||''}</span><span class="uc-active-dot">● ACTIVE</span></div>
                <div class="uc-right">${predHtml}<div class="tog ${u.enabled?'on':''}" onclick="event.stopPropagation();toggleUplink('${u.name}')"></div></div>
            </div>
            <div class="mg">
                <div class="mc"><div class="l">RTT</div><div class="v ${rttC}">${rtt}</div></div>
                <div class="mc"><div class="l">Loss</div><div class="v ${lossC}">${loss}</div></div>
                <div class="mc"><div class="l">Fail</div><div class="v ${u.consec_fail>0?'b':'g'}">${u.consec_fail||0}</div></div>
            </div>
            ${extra}
            <div class="risk-bar"><div class="risk-fill" style="width:${Math.min(100,risk*100)}%;background:${riskCol}"></div></div>
        </div>`;
    }).join('');
}

// ─── Throughput tracking with INDEPENDENT down/up ───
let tpHist=[], peakD=0, peakU=0;
let smoothD=0, smoothU=0, prevD=null, prevU=null;

function updateThroughput(rawD, rawU){
    // Fix #3: independent smoothing, ignore if both identical (daemon bug)
    // Use 40/60 weighting for faster response
    smoothD = smoothD*0.4 + rawD*0.6;
    smoothU = smoothU*0.4 + rawU*0.6;
    // Clamp tiny values
    if(smoothD<0.01) smoothD=0;
    if(smoothU<0.01) smoothU=0;
    if(smoothD>peakD) peakD=smoothD;
    if(smoothU>peakU) peakU=smoothU;

    // Header
    document.getElementById('spd-down').textContent=smoothD.toFixed(1);
    document.getElementById('spd-up').textContent=smoothU.toFixed(1);

    // Bars — independent scaling with adaptive max
    const maxD=Math.max(5,peakD*1.2);
    const maxU=Math.max(5,peakU*1.2);
    document.getElementById('tp-d-fill').style.width=Math.min(100,smoothD/maxD*100)+'%';
    document.getElementById('tp-u-fill').style.width=Math.min(100,smoothU/maxU*100)+'%';
    document.getElementById('tp-d-val').textContent=smoothD.toFixed(1)+' Mbps';
    document.getElementById('tp-u-val').textContent=smoothU.toFixed(1)+' Mbps';
    document.getElementById('tp-d-peak').textContent='peak: '+peakD.toFixed(1);
    document.getElementById('tp-u-peak').textContent='peak: '+peakU.toFixed(1);

    // History for chart
    tpHist.push({ts:Date.now(),d:smoothD,u:smoothU});
    if(tpHist.length>120) tpHist=tpHist.slice(-120);
    drawChart();
}

function drawChart(){
    const canvas=document.getElementById('tp-canvas');
    if(!canvas) return;
    const ctx=canvas.getContext('2d');
    const W=canvas.parentElement.offsetWidth,H=canvas.parentElement.offsetHeight;
    canvas.width=W;canvas.height=H;
    if(tpHist.length<2) return;

    const maxVal=Math.max(1,...tpHist.map(h=>Math.max(h.d,h.u)))*1.2;
    ctx.clearRect(0,0,W,H);

    // Grid lines
    ctx.strokeStyle='rgba(42,42,78,.4)';ctx.lineWidth=0.5;
    for(let i=1;i<=4;i++){const y=H-H*(i/4);ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}

    // Download fill
    ctx.beginPath();
    ctx.moveTo(0,H);
    tpHist.forEach((h,i)=>{const x=W*i/(tpHist.length-1);const y=H-H*(h.d/maxVal);ctx.lineTo(x,y)});
    ctx.lineTo(W,H);ctx.closePath();
    ctx.fillStyle='rgba(0,255,136,.12)';ctx.fill();

    // Download line
    ctx.beginPath();
    tpHist.forEach((h,i)=>{const x=W*i/(tpHist.length-1);const y=H-H*(h.d/maxVal);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y)});
    ctx.strokeStyle='var(--green)';ctx.lineWidth=1.5;ctx.stroke();

    // Upload line
    ctx.beginPath();
    tpHist.forEach((h,i)=>{const x=W*i/(tpHist.length-1);const y=H-H*(h.u/maxVal);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y)});
    ctx.strokeStyle='var(--purple)';ctx.lineWidth=1;ctx.stroke();

    // Scale label
    ctx.fillStyle='var(--dim)';ctx.font='8px monospace';
    ctx.fillText(maxVal.toFixed(1)+' Mbps',4,10);
    ctx.fillText('↓ Down',W-60,10);ctx.fillStyle='var(--purple)';ctx.fillText('↑ Up',W-60,20);
}

// ─── Main SSE update ───
function updateDashboard(s){
    const modeBadge=document.getElementById('badge-mode');
    modeBadge.textContent=s.mode;modeBadge.className='badge mode-'+s.mode.toLowerCase();
    /* ECMP status sync */
    if(Date.now()>ecmpCooldown){
        const ecmpSt=document.getElementById("ecmp-status");
        const ecmpTog=document.getElementById("ecmp-toggle");
        if(s.mode==="ECMP"&&s.ecmp_mask>0){
            if(!ecmpActive){ecmpActive=true;ecmpTog.classList.add("on");}
            const names=["cell_a","cell_b","sl_a","sl_b","fa","fb"];
            const active=names.filter((_,i)=>s.ecmp_mask&(1<<i));
            ecmpSt.textContent="ACTIVE: "+active.join("+").toUpperCase();
            ecmpSt.style.color="var(--green)";
        }else if(s.mode!=="ECMP"){
            if(ecmpActive){ecmpActive=false;ecmpTog.classList.remove("on");}
            ecmpSt.textContent="OFF";ecmpSt.style.color="var(--muted)";
        }
    }
    const stateBadge=document.getElementById('badge-state');
    stateBadge.textContent=s.state;stateBadge.className='badge st-'+s.state.toLowerCase();
    const dupB=document.getElementById('badge-dup');
    if(s.dup_enabled){dupB.textContent='DUP ON';dupB.style.background='rgba(0,255,136,.1)';dupB.style.color='var(--green)';}
    else{dupB.textContent='DUP OFF';dupB.style.background='rgba(100,100,100,.15)';dupB.style.color='var(--muted)';}

    // Active uplink — TRUTH from daemon
    const au=s.active_uplink||'--';
    if(s.mode==='ECMP'&&s.ecmp_mask>0){const names=['cell_a','cell_b','sl_a','sl_b','fa','fb'];const active=names.filter((_,i)=>s.ecmp_mask&(1<<i));document.getElementById('ap-name').textContent='⚡'+active.join('+').toUpperCase();}else{document.getElementById('ap-name').textContent=(UL[au]||au).toUpperCase();}
    document.getElementById('ap-detail').textContent=`${s.mode} | ${s.state} | Sw: ${s.switches_this_window||0}`;
    document.getElementById('apb').className='apb'+(s.state!=='NORMAL'?' warn':'');
    document.getElementById('ctrl-badge').textContent='CTRL-'+(s.active_controller===1?'B':'A');
    if(s.last_cmd) document.getElementById('cmd-badge').textContent=s.last_cmd.detail||s.last_cmd.result||'--';

    // Uplinks
    window._ecmpMode=(s.mode==="ECMP");window._ecmpMask=s.ecmp_mask||0;renderUplinks(s.uplinks||[],au);

    // KPIs
    const avail=(s.uplinks||[]).filter(u=>u.enabled&&u.available);
    const enabled=(s.uplinks||[]).filter(u=>u.enabled);
    document.getElementById('kpi-paths').textContent=avail.length+'/'+enabled.length;
    if(avail.length>0){
        const sorted=[...avail].sort((a,b)=>(a.rtt_ms||999)-(b.rtt_ms||999));
        document.getElementById('kpi-best').textContent=(sorted[0].rtt_ms||0).toFixed(0)+'ms';
        document.getElementById('kpi-best-n').textContent=UL[sorted[0].name]||sorted[0].name;
    }
    const gr=s.global_risk||0;
    const rEl=document.getElementById('kpi-risk');
    rEl.textContent=gr.toFixed(2);rEl.style.color=gr>.5?'var(--red)':gr>.2?'var(--yellow)':'var(--green)';
    document.getElementById('kpi-sw').textContent=s.switches_this_window||0;
    /* GPS / Mobile panel */
    if(s.gps){
        document.getElementById("gps-speed").textContent=s.gps.speed_mph?Math.round(s.gps.speed_mph):"0";
        document.getElementById("gps-heading").textContent=s.gps.heading?Math.round(s.gps.heading)+"°":"--";
        document.getElementById("gps-lat").textContent=s.gps.lat?s.gps.lat.toFixed(5):"--";
        document.getElementById("gps-lon").textContent=s.gps.lon?s.gps.lon.toFixed(5):"--";
        document.getElementById("gps-fix").textContent=s.gps.valid?"3D FIX":"NO FIX";
        document.getElementById("gps-fix").style.color=s.gps.valid?"var(--green)":"var(--red)";
    }
    /* Cell info from active uplink */
    const cellUp=(s.uplinks||[]).find(u=>u.cellular&&u.cellular.connected);
    if(cellUp&&cellUp.cellular){
        document.getElementById("gps-cell").textContent=cellUp.cellular.cell_id||"--";
        document.getElementById("gps-band").textContent=cellUp.cellular.band||"--";
    }
    /* GPS Map */
    if(s.gps&&s.gps.valid&&s.gps.lat!==0){
        if(!window._gpsMap){
            window._gpsMap=L.map("gps-map",{zoomControl:false,attributionControl:false}).setView([s.gps.lat,s.gps.lon],14);
            L.tileLayer("https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png").addTo(window._gpsMap);
            window._gpsMarker=L.circleMarker([s.gps.lat,s.gps.lon],{radius:6,color:"#00d4ff",fillColor:"#00d4ff",fillOpacity:0.8}).addTo(window._gpsMap);
            window._gpsTrail=L.polyline([],{color:"#00ff88",weight:2,opacity:0.6}).addTo(window._gpsMap);
            window._gpsHeat=[];
        }
        window._gpsMarker.setLatLng([s.gps.lat,s.gps.lon]);
        window._gpsMap.panTo([s.gps.lat,s.gps.lon]);
        window._gpsTrail.addLatLng([s.gps.lat,s.gps.lon]);
        if(window._gpsTrail.getLatLngs().length>500)window._gpsTrail.getLatLngs().splice(0,1);
        /* Heat bubble on switch events */
        if(s.state==="SWITCHING"||s.state==="PROTECT"){
            L.circleMarker([s.gps.lat,s.gps.lon],{radius:12,color:"#ff4444",fillColor:"#ff4444",fillOpacity:0.3,weight:1}).addTo(window._gpsMap);
        }
    }

    if(s.run_id){const m=s.run_id.match(/(\d{4})(\d{2})(\d{2})_(\d{2})(\d{2})(\d{2})/);
        if(m){const st=new Date(Date.UTC(m[1],m[2]-1,m[3],m[4],m[5],m[6]));const mins=Math.floor((Date.now()-st)/60000);if(mins<0)return;
            document.getElementById('kpi-up').textContent=Math.floor(mins/60)+'h '+mins%60+'m';}}

    // Throughput — use raw values from daemon
    updateThroughput(s.throughput_down_mbps||0, s.throughput_up_mbps||0);

    // Prediction
    const activeU=(s.uplinks||[]).find(u=>u.active);
    const nonAct=avail.filter(u=>!u.active);
    const sc=nonAct.map(u=>({n:u.name,s:(u.rtt_ms||999)+(u.risk_now||0)*100+(u.loss_pct||0)*10})).sort((a,b)=>a.s-b.s);
    const ti2=sc.reduce((s,x)=>s+1000/(x.s+1),0);
    const pr=sc.map(x=>({n:x.n,p:Math.round((1000/(x.s+1))/ti2*100)}));
    document.getElementById('pred-a').textContent=activeU?activeU.name.toUpperCase():'--';
    document.getElementById('pred-1').textContent=pr[0]?pr[0].n.toUpperCase()+' ('+pr[0].p+'%)':'--';
    document.getElementById('pred-2').textContent=pr[1]?pr[1].n.toUpperCase()+' ('+pr[1].p+'%)':'--';
    document.getElementById('pred-3').textContent=pr[2]?pr[2].n.toUpperCase()+' ('+pr[2].p+'%)':'--';
}

// ─── SSE ───
let lastState='';
const evtSource=new EventSource('/api/stream');
evtSource.onmessage=(e)=>{
    const s=JSON.parse(e.data);
    if(s.state!==lastState&&lastState){
        if(s.state==='PROTECT')addLog('trigger','TRIPWIRE: '+s.trigger);
        else if(s.state==='NORMAL'&&lastState!=='NORMAL')addLog('info','Returned to NORMAL');
    }
    lastState=s.state;
    checkChanges(s);
    updateDashboard(s);
};
evtSource.onerror=()=>console.log('SSE reconnecting...');

// ─── Event Log ───
const logArr=[];let logFilter='all';
function addLog(level,msg,gps,persist=true){
    const now=new Date();
    const ts=now.toTimeString().split(' ')[0]+'.'+String(now.getMilliseconds()).padStart(3,'0');
    logArr.push({t:ts,l:level,m:msg,g:gps||null});
    if(logArr.length>500) logArr.shift();
    if(persist) fetch('/api/log/write',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({type:level,message:msg,detail:gps||''})}).catch(()=>{});
    renderLog();
}
function renderLog(){
    const f=logFilter==='all'?logArr:logArr.filter(e=>e.l===logFilter);
    document.getElementById('log-inner').innerHTML=f.slice(-80).map(e=>
        `<div class="le"><span class="lt2">${e.t}</span><span class="ll ${e.l}">${e.l.toUpperCase()}</span><span>${e.m}</span>${e.g?`<span style="color:var(--dim);font-size:7px;margin-left:3px">[${e.g}]</span>`:''}</div>`
    ).join('');
    const c=document.getElementById('log-content');c.scrollTop=c.scrollHeight;
}
function filterLog(f,el){logFilter=f;document.querySelectorAll('.log-controls .log-btn').forEach(b=>b.classList.remove('active'));if(el)el.classList.add('active');renderLog();}
function exportLog(){const csv='Time,Level,Message\n'+logArr.map(e=>`${e.t},${e.l},"${e.m}"`).join('\n');const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));a.download='pathsteer_log.csv';a.click();}

// ─── State changes ───
let prevSt=null,prevMode=null,prevAct=null;
var llmCPT=0.002,llmSaved=0;
function checkChanges(s){
    const gps=s.gps?.valid?`${s.gps.lat.toFixed(5)},${s.gps.lon.toFixed(5)}`:null;
    if(prevSt!==s.state&&prevSt!==null){
        if(s.state==='PROTECT')addLog('trigger',`TRIPWIRE: ${s.trigger}`,gps);
        else if(s.state==='SWITCHING')addLog('warn','Executing path switch',gps);
        else if(s.state==='HOLDING')addLog('switch',`Switched to ${s.active_uplink}`,gps);
        else if(s.state==='NORMAL')addLog('info','Returned to NORMAL',gps);
    }
    if(prevMode!==s.mode&&prevMode!==null) addLog('info',`Mode: ${s.mode}`,gps);
    if(prevAct!==s.active_uplink&&prevAct!==null){
        addLog('switch',`Active: ${prevAct} → ${s.active_uplink}`,gps);
        fetch('/api/llm/status').then(r=>r.json()).then(d=>{if(d.running&&d.total_tokens>0){let v=d.total_tokens*llmCPT;llmSaved+=v;addLog('switch',`💰 LLM saved $${v.toFixed(4)}`,gps);}}).catch(()=>{});
    }
    prevSt=s.state;prevMode=s.mode;prevAct=s.active_uplink;
}

// ─── Actions ───
async function toggleUplink(name){_lock=Date.now()+2000;const r=await fetch('/api/uplink/toggle',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name})});const d=await r.json();const card=document.querySelector(`.uc[data-name="${name}"]`);if(card){const t=card.querySelector('.tog');if(t)t.classList.toggle('on',d.enabled);card.style.opacity=d.enabled?'1':'0.35';}}
async function forceActive(name){await fetch('/api/control/force',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({uplink:name})});addLog('switch','Force → '+name.toUpperCase());}
async function clearForce(){await fetch('/api/control/force',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({uplink:'auto'})});addLog('info','Cleared force → AUTO');}
let ecmpActive=false;let ecmpCooldown=0;
async function toggleEcmp(){
    ecmpActive=!ecmpActive;
    const tog=document.getElementById("ecmp-toggle");
    if(ecmpActive){
        const checks=document.querySelectorAll(".ecmp-link:checked");
        const uplinks=[...checks].map(c=>c.value);
        if(uplinks.length<2){addLog("info","ECMP needs 2+ links");ecmpActive=false;tog.classList.remove("on");return;}
        tog.classList.add("on");
        ecmpCooldown=Date.now()+5000;await fetch("/api/control/ecmp",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({enabled:true,uplinks:uplinks})});
        addLog("info","ECMP ON: "+uplinks.join("+").toUpperCase());
    }else{
        tog.classList.remove("on");
        ecmpCooldown=Date.now()+5000;await fetch("/api/control/ecmp",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({enabled:false})});
        addLog("info","ECMP OFF → TRIPWIRE");
    }
}
document.querySelectorAll(".ecmp-link").forEach(cb=>{
    cb.addEventListener("change",async function(){
        if(!ecmpActive)return;
        const checks=document.querySelectorAll(".ecmp-link:checked");
        const uplinks=[...checks].map(c=>c.value);
        if(uplinks.length<2){addLog("info","ECMP needs 2+ links");return;}
        ecmpCooldown=Date.now()+5000;await fetch("/api/control/ecmp",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({enabled:true,uplinks:uplinks})});
        addLog("info","ECMP updated: "+uplinks.join("+").toUpperCase());
    });
});
async function switchController(c){await fetch('/api/control/controller',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({controller:c})});addLog('switch','Controller → '+(c===0?'A':'B'));}

// ─── WG Tunnels with live throughput ───
let wgRates={};
async function fetchTunnels(probe){
    try{
        const [tR,rR]=await Promise.all([
            fetch(probe?'/diag/api/tunnels?probe=true':'/diag/api/tunnels'),
            fetch('/diag/api/throughput/now').catch(()=>({json:()=>({tunnels:[]})}))
        ]);
        const td=await tR.json();const rd=await rR.json();
        // Merge rates
        (rd.tunnels||[]).forEach(r=>{wgRates[r.tunnel]={rx:r.rx_mbps||0,tx:r.tx_mbps||0};});
        renderTunnels(td.tunnels||[]);
    }catch(e){console.error('Tunnel fetch:',e);}
}

function renderTunnels(T){
    const tb=document.getElementById('tun-tbody');
    if(!T.length){tb.innerHTML='<tr><td colspan="10" style="text-align:center;color:var(--muted)">No data</td></tr>';return;}
    let up=0;
    tb.innerHTML=T.map(t=>{
        const st=t.status||'unknown',dc=st==='UP'?'up':st==='STALE'?'stale':'down';
        if(st==='UP')up++;
        const cc=t.controller==='A'?'a':'b';
        const hc=t.last_handshake_sec<0?'b':t.last_handshake_sec>180?'w':'g';
        const rates=wgRates[t.tunnel]||{rx:0,tx:0};
        const pv=t.probe_rtt_ms!=null?`<span class="stat-val ${t.probe_rtt_ms>100?'w':'g'}">${t.probe_rtt_ms}ms</span>`:'<span style="color:var(--dim)">--</span>';
        return `<tr>
            <td><span class="sd ${dc}"></span>${st}</td>
            <td style="font-weight:600">${t.tunnel}</td>
            <td>${t.uplink_label||t.uplink||'--'}</td>
            <td><span class="ctrl-b ${cc}">CTRL-${t.controller}</span></td>
            <td><span class="stat-val ${hc}">${t.last_handshake_display||'--'}</span></td>
            <td>${t.rx_display||'--'}</td>
            <td>${t.tx_display||'--'}</td>
            <td style="color:var(--green);font-weight:600">${rates.rx.toFixed(2)}</td>
            <td style="color:var(--purple);font-weight:600">${rates.tx.toFixed(2)}</td>
            <td>${pv}</td>
        </tr>`;
    }).join('');

    // Update compact WG in left pane
    updateWgCompact(T);
}

function updateWgCompact(T){
    const byUL={};
    T.forEach(t=>{const ul=t.uplink_label||t.uplink||'?';if(!byUL[ul])byUL[ul]={up:0,tot:0,rx:0,tx:0};byUL[ul].tot++;if(t.status==='UP')byUL[ul].up++;const r=wgRates[t.tunnel]||{rx:0,tx:0};byUL[ul].rx+=r.rx;byUL[ul].tx+=r.tx;});
    const totalUp=T.filter(t=>t.status==='UP').length;
    document.getElementById('wg-sum').textContent=totalUp+'/12';
    document.getElementById('wg-rows').innerHTML=Object.entries(byUL).map(([name,c])=>{
        const cls=c.up===c.tot?'up':c.up>0?'stale':'down';
        const rate=c.rx+c.tx;
        return `<div class="wg-row"><span><span class="wg-dot ${cls}"></span>${name}</span><span class="wg-rate">${rate>0.01?rate.toFixed(2)+' Mbps':'idle'}</span></div>`;
    }).join('');
}

async function runProbe(){const b=document.getElementById('probe-btn');b.textContent='⏳ Probing...';b.disabled=true;await fetchTunnels(true);b.textContent='⚡ PROBE ALL RTT';b.disabled=false;}

// ─── Diagnostics ───
async function fetchDiag(){
    try{
        const [mR,pR,nR]=await Promise.all([fetch('/diag/api/metrics'),fetch('/diag/api/path'),fetch('/diag/api/namespaces')]);
        const m=await mR.json(),p=await pR.json(),ns=await nR.json();
        const fo=m.failover||{},st=m.stability||{},ld=m.load||{};
        document.getElementById('fo-t').textContent=fo.total_tests||0;
        document.getElementById('fo-s').textContent=(fo.success_rate||0)+'%';
        document.getElementById('fo-d50').textContent=(fo.detection_p50||0)+' ms';
        document.getElementById('fo-w').textContent=(fo.worst_total_ms||0)+' ms';
        document.getElementById('st-av').textContent=(st.availability_pct||0).toFixed(2)+'%';
        document.getElementById('st-up').textContent=st.uptime_display||'--';
        document.getElementById('st-mt').textContent=st.mtbf_display||'--';
        document.getElementById('st-f').textContent=st.total_failures||0;
        const cp=ld.cpu_pct||0;const cpEl=document.getElementById('sy-cpu');
        cpEl.textContent=cp.toFixed(1)+'%';cpEl.className='stat-val '+(cp>80?'b':cp>50?'w':'g');
        document.getElementById('sy-ld').textContent=(ld.load_1m||0).toFixed(2);
        document.getElementById('sy-mem').textContent=(ld.mem_used_mb||0)+'/'+(ld.mem_total_mb||0)+' MB';
        const lb={fa:'FIBER A',fb:'FIBER B',sl_a:'SL_A',sl_b:'SL_B',cell_a:'CELL_A',cell_b:'CELL_B'};
        document.getElementById('pv-r').textContent=lb[p.active_from_route]||p.active_from_route||'--';
        document.getElementById('pv-d').textContent=lb[p.daemon_says]||p.daemon_says||'--';
        const mm=document.getElementById('pv-m');mm.textContent=p.match?'✓ MATCH':'✗ MISMATCH';mm.className='stat-val '+(p.match?'g':'b');
        document.getElementById('ns-grid').innerHTML=Object.entries(ns).map(([n,i])=>
            `<div class="ns-card ${i.exists&&i.ipv4_forward?'ok':'bad'}"><div class="nn">${n}</div><div class="nd">${i.exists?'UP':'DOWN'} | IFs: ${i.ifaces_up||0} | Fwd: ${i.ipv4_forward?'✓':'✗'}</div></div>`
        ).join('');
    }catch(e){console.error('Diag:',e);}
}

// ─── Initial loads ───
addLog('info','Guardian UI connected',null,false);
fetch('/api/status').then(r=>r.json()).then(updateDashboard).catch(()=>{});
setInterval(()=>fetchTunnels(false),10000); // refresh WG rates every 10s
fetchTunnels(false);
async function loadHistory(){try{const r=await fetch('/api/events/history?limit=50');const ev=await r.json();ev.reverse().forEach(e=>{const ts=e.timestamp?e.timestamp.split(' ')[1]||e.timestamp.substring(11,19):'';logArr.push({t:ts,l:e.type,m:e.message,g:e.detail||null});});renderLog();}catch(e){}}
loadHistory();

// ─── Floating popouts (Chaos, LLM, Flow, History) ───
function _drag(id,e){const el=document.getElementById(id);const dx=e.clientX-el.offsetLeft,dy=e.clientY-el.offsetTop;document.onmousemove=function(e){el.style.left=(e.clientX-dx)+'px';el.style.top=(e.clientY-dy)+'px';el.style.right='auto';el.style.bottom='auto'};document.onmouseup=function(){document.onmousemove=null};}

function chaosFloat(){
    if(document.getElementById('chaos-f')){document.getElementById('chaos-f').remove();return;}
    let w=document.createElement('div');w.id='chaos-f';
    w.style.cssText='position:fixed;top:60px;right:20px;width:340px;background:var(--panel);border:2px solid var(--orange);border-radius:8px;z-index:9998;box-shadow:0 0 30px rgba(255,102,0,.2);padding:12px';
    w.innerHTML=`<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;cursor:move" onmousedown="_drag('chaos-f',event)"><span style="color:var(--orange);font-weight:bold;font-size:11px">🎲 Chaos Injection</span><button onclick="document.getElementById('chaos-f').remove()" style="background:none;border:none;color:var(--red);cursor:pointer;font-size:16px;font-family:inherit">✕</button></div>
    <div style="font-size:9px;color:var(--muted);margin-bottom:6px">Inject latency/loss into daemon scoring. Must exceed thresholds to trigger failover.</div>
    <div id="chaos-ctrl"></div>
    <div style="margin-top:6px;display:flex;gap:4px">
        <button onclick="chaosApply()" style="flex:1;background:var(--orange);color:#000;border:none;padding:5px;font-family:inherit;font-size:9px;cursor:pointer;border-radius:3px;font-weight:bold">APPLY</button>
        <button onclick="chaosReset()" style="flex:1;background:var(--card);color:var(--text);border:1px solid var(--border);padding:5px;font-family:inherit;font-size:9px;cursor:pointer;border-radius:3px">RESET</button>
    </div>`;
    document.body.appendChild(w);
    fetch('/api/status').then(r=>r.json()).then(s=>{
        document.getElementById('chaos-ctrl').innerHTML=(s.uplinks||[]).map(u=>`<div style="margin-bottom:4px;padding:4px;background:var(--card);border-radius:3px">
            <div style="font-weight:bold;font-size:9px;margin-bottom:2px">${UL[u.name]||u.name}</div>
            <div style="display:flex;gap:6px;align-items:center;font-size:8px">
                <label>RTT+<input type="number" id="ch-r-${u.name}" value="0" min="0" max="5000" step="50" style="width:45px;background:var(--bg);color:var(--text);border:1px solid var(--border);padding:2px;font-size:8px;font-family:inherit;border-radius:2px">ms</label>
                <label>Loss+<input type="number" id="ch-l-${u.name}" value="0" min="0" max="100" step="10" style="width:35px;background:var(--bg);color:var(--text);border:1px solid var(--border);padding:2px;font-size:8px;font-family:inherit;border-radius:2px">%</label>
            </div>
        </div>`).join('');
    });
}
async function chaosApply(){const s=await(await fetch('/api/status')).json();const c={};(s.uplinks||[]).forEach(u=>{const r=parseInt(document.getElementById('ch-r-'+u.name)?.value||0);const l=parseInt(document.getElementById('ch-l-'+u.name)?.value||0);if(r>0||l>0)c[u.name]={rtt_add:r,loss_add:l};});await fetch('/api/chaos/inject',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(c)});addLog('warn','Chaos: '+JSON.stringify(c));}
async function chaosReset(){await fetch('/api/chaos/reset',{method:'POST'});addLog('info','Chaos reset');}

function llmFloat(){
    if(document.getElementById('llm-f')){document.getElementById('llm-f').remove();return;}
    let w=document.createElement('div');w.id='llm-f';
    w.style.cssText='position:fixed;bottom:20px;right:20px;width:600px;height:60vh;background:var(--panel);border:2px solid var(--blue);border-radius:8px;z-index:9998;display:flex;flex-direction:column;box-shadow:0 0 30px rgba(0,212,255,.2);resize:both;overflow:hidden';
    w.innerHTML=`<div style="display:flex;justify-content:space-between;align-items:center;padding:6px 10px;background:var(--card);cursor:move" onmousedown="_drag('llm-f',event)"><span style="color:var(--blue);font-size:11px;font-weight:bold">⚡ LLM Lab</span><button onclick="document.getElementById('llm-f').remove()" style="background:none;border:none;color:var(--red);font-size:14px;cursor:pointer;font-family:inherit">✕</button></div>
    <div style="padding:6px 10px;flex-shrink:0">
        <textarea id="llm-fl-p" rows="2" style="width:100%;background:var(--bg);color:var(--text);border:1px solid var(--border);padding:6px;font-size:11px;font-family:inherit;border-radius:3px;resize:vertical">${document.getElementById('llm-prompt').value}</textarea>
        <div style="display:flex;gap:4px;margin-top:4px">
            <select id="llm-fl-l" style="background:var(--card);color:var(--text);border:1px solid var(--border);font-size:10px;font-family:inherit;padding:4px;border-radius:3px"><option value="0">Continuous</option><option value="1">1</option><option value="5">5</option><option value="10">10</option></select>
            <button onclick="llmFlGo()" style="flex:1;background:var(--green);color:var(--bg);border:none;padding:5px;font-size:10px;font-family:inherit;cursor:pointer;border-radius:3px;font-weight:bold">▶ START</button>
            <button onclick="fetch('/api/llm/stop',{method:'POST'})" style="background:var(--red);color:white;border:none;padding:5px 10px;font-size:10px;font-family:inherit;cursor:pointer;border-radius:3px;font-weight:bold">■</button>
        </div>
        <div style="display:flex;gap:8px;margin-top:4px;font-size:9px"><div>⚡ <span id="llm-fl-tps" style="color:var(--blue);font-weight:bold">0</span> tok/s</div><div>📊 <span id="llm-fl-tot" style="color:var(--green);font-weight:bold">0</span></div><div>❌ <span id="llm-fl-err" style="color:var(--red)">0</span></div></div>
    </div>
    <div style="flex:1;overflow-y:auto;margin:0 10px 10px;background:var(--bg);border:1px solid var(--border);border-radius:3px;padding:8px;font-size:11px;line-height:1.6" id="llm-fl-out">Waiting...</div>`;
    document.body.appendChild(w);llmFlPoll();
}
async function llmFlGo(){const p=document.getElementById('llm-fl-p').value;const l=parseInt(document.getElementById('llm-fl-l').value);document.getElementById('llm-prompt').value=p;await fetch('/api/llm/start',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({prompt:p,loop_count:l})});}
function llmFlPoll(){if(!document.getElementById('llm-f'))return;fetch('/api/llm/status').then(r=>r.json()).then(d=>{const e=id=>document.getElementById(id);const s=(id,v)=>{const el=e(id);if(el)el.textContent=v;};s('llm-fl-tps',d.tokens_per_sec||0);s('llm-fl-tot',d.total_tokens||0);s('llm-fl-err',d.errors||0);const o=e('llm-fl-out');if(o&&d.full_log){o.textContent=d.full_log;o.scrollTop=o.scrollHeight;}}).catch(()=>{});setTimeout(llmFlPoll,500);}

function flowFloat(){if(document.getElementById('flow-f')){document.getElementById('flow-f').remove();return;}let w=document.createElement('div');w.id='flow-f';w.style.cssText='position:fixed;top:60px;left:280px;width:650px;height:60vh;background:var(--panel);border:2px solid var(--purple);border-radius:8px;z-index:9997;display:flex;flex-direction:column;resize:both;overflow:hidden;box-shadow:0 0 30px rgba(123,44,191,.2)';w.innerHTML=`<div style="display:flex;justify-content:space-between;align-items:center;padding:6px 10px;background:var(--card);cursor:move" onmousedown="_drag('flow-f',event)"><span style="color:var(--purple);font-size:11px;font-weight:bold">📡 Flows</span><button onclick="document.getElementById('flow-f').remove()" style="background:none;border:none;color:var(--red);font-size:14px;cursor:pointer;font-family:inherit">✕</button></div><div id="flow-f-body" style="flex:1;overflow-y:auto;padding:8px;font-size:9px;color:var(--muted)">Loading...</div>`;document.body.appendChild(w);}
setInterval(()=>{fetch('/api/flows').then(r=>r.json()).then(d=>{const b=document.getElementById('flow-f-body');if(b)b.textContent=JSON.stringify(d,null,2);}).catch(()=>{});},3000);

function logHistFloat(){if(document.getElementById('logh-f')){document.getElementById('logh-f').remove();return;}let w=document.createElement('div');w.id='logh-f';w.style.cssText='position:fixed;top:80px;left:300px;width:700px;height:60vh;background:var(--panel);border:2px solid var(--purple);border-radius:8px;z-index:9996;display:flex;flex-direction:column;resize:both;overflow:hidden;box-shadow:0 0 30px rgba(123,44,191,.2)';
w.innerHTML=`<div style="display:flex;justify-content:space-between;align-items:center;padding:6px 10px;background:var(--card);cursor:move" onmousedown="_drag('logh-f',event)"><span style="color:var(--purple);font-size:11px;font-weight:bold">📋 Event History</span><button onclick="document.getElementById('logh-f').remove()" style="background:none;border:none;color:var(--red);font-size:14px;cursor:pointer;font-family:inherit">✕</button></div>
<div style="display:flex;gap:4px;padding:6px 10px;background:var(--card);border-bottom:1px solid var(--border)"><button onclick="lhLoad('1h')" class="log-btn active">1H</button><button onclick="lhLoad('6h')" class="log-btn">6H</button><button onclick="lhLoad('24h')" class="log-btn">24H</button></div>
<div id="logh-body" style="flex:1;overflow-y:auto;padding:8px;font-size:9px"></div>`;
document.body.appendChild(w);lhLoad('1h');}
async function lhLoad(p){const ms=p==='1h'?3600000:p==='6h'?21600000:86400000;const now=new Date();try{const r=await fetch(`/api/log/query?start=${new Date(now-ms).toISOString()}&end=${now.toISOString()}&type=all&limit=500`);const d=await r.json();const b=document.getElementById('logh-body');if(b){if(!d.events?.length){b.innerHTML='<div style="color:var(--muted);padding:16px;text-align:center">No events</div>';return;}b.innerHTML=d.events.map(e=>{const c=e.type==='switch'?'var(--yellow)':e.type==='trigger'?'var(--red)':'var(--muted)';return`<div style="padding:2px 0;border-bottom:1px solid var(--border);display:flex;gap:6px"><span style="color:var(--muted);min-width:120px">${(e.server_time||'').replace('T',' ').slice(0,19)}</span><span style="color:${c};min-width:50px;font-weight:bold">${(e.type||'info').toUpperCase()}</span><span>${e.message||''}</span></div>`;}).join('');b.scrollTop=b.scrollHeight;}}catch(e){console.error(e);}}
</script>
</body>
</html>
